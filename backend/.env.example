# ============================================
#  NEON PostgreSQL (TAVSIYA QILINADI)
# ============================================
# console.neon.tech'ga kirib proyekt yarating va connection string'ni nusxa oling
# Shakli: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL="postgresql://neondb_owner:PAROL@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# ============================================
#  Mahalliy PostgreSQL (agar Neon'siz ishlamoqchi bo'lsangiz)
#  DATABASE_URL ni bo'sh qoldiring va shu 4 qatorni ishlating:
# ============================================
# DB_NAME=EduTest
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_HOST=localhost
# DB_PORT=5432

# ============================================
#  SERVER
# ============================================
PORT=5000
JWT_SECRET=change-this-to-random-secret-string

# ============================================
#  GROQ AI (bepul — console.groq.com)
# ============================================
# https://console.groq.com'ga kiring va API key oling
GROQ_API_KEY=gsk_your_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
